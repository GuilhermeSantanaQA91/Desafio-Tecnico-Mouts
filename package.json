{
	"name": "desafio-tecnico-mouts",
	"version": "1.0.0",
	"description": "Suíte de testes automatizados do Site ServeRest",
	"main": "index",
	"scripts": {
		"postinstall": "cypress install",
		"prepare": "husky",
		"clean": "cypress cache clear",
		"clean:reports": "node -e \"require('fs-extra').removeSync('cypress/reports')\"",
		"lint": "eslint . --fix",
		"lint:check": "eslint .",
		"format": "prettier --write .",
		"cy:run": "pnpm run clean:reports && cypress run --env env=dev",
		"cy:run:api": "pnpm run clean:reports && cypress run --env env=dev,grepTags=@api",
		"cy:run:e2e": "pnpm run clean:reports && cypress run --env env=dev,grepTags=@e2e",
		"cy:run:report": "pnpm run cy:run && pnpm run cy:report",
		"cy:open": "cypress open --env env=dev",
		"cy:open:api": "cypress open --env env=dev,grepTags=@api",
		"cy:open:e2e": "cypress open --env env=dev,grepTags=@e2e",
		"cy:open:mcp": "cypress open --env env=dev,mcpDebug=true,mcpPort=60562 --e2e --browser=chrome",
		"cy:report": "npx cypress-mochawesome-reporter merge"
	},
	"keywords": [
		"cypress",
		"e2e",
		"api",
		"serveRest"
	],
	"author": "Guilherme Santana <guilherme.santanasilvaa@gmail.com>",
	"license": "MIT",
	"devDependencies": {
		"@cypress/grep": "5.1.0",
		"@eslint/js": "^10.0.1",
		"@faker-js/faker": "^10.4.0",
		"ajv": "^8.20.0",
		"ajv-formats": "^3.0.1",
		"cross-env": "^10.1.0",
		"cypress": "15.18.1",
		"cypress-mochawesome-reporter": "^4.0.2",
		"cypress-multi-reporters": "^2.0.5",
		"cypress-plugin-api": "^2.11.2",
		"cypress-plugin-xhr-toggle": "^1.3.0",
		"dotenv": "17.4.2",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-cypress": "^6.3.1",
		"eslint-plugin-prettier": "^5.5.5",
		"fs-extra": "^11.3.4",
		"gerador-validador-cnpj": "^3.0.0",
		"gerador-validador-cpf": "^6.3.0",
		"husky": "^9.1.7",
		"lint-staged": "^17.0.4",
		"prettier": "^3.8.3"
	},
	"packageManager": "pnpm@11.12.0+sha512.820a6fbd0d9f04c226638002aead1e45340a9139dd5dc077c1d83ef44aa2481c8eb6637b4c9aa696a3c7e35ba818e49cf27213e5f2b91138d09b7a3e26e898ba",
	"lint-staged": {
		"cypress/**/*.js": [
			"eslint --fix",
			"prettier --write"
		],
		"*.{json,mjs,cjs}": [
			"prettier --write"
		]
	}
}
